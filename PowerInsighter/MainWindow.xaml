<Window x:Class="PowerInsighter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:PowerInsighter"
    xmlns:helpers="clr-namespace:PowerInsighter.Helpers"
    mc:Ignorable="d"
    Title="PowerInsighter - Power BI Model Analyzer" 
    Height="700" 
    Width="1200"
    WindowStartupLocation="CenterScreen">
<Grid Margin="10">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with Connect Button -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button
                Grid.Column="0"
                Width="220"
                Height="40"
                Content="🔌 Connect to Power BI Desktop"
                Command="{Binding ConnectCommand}"
                FontSize="14"
                FontWeight="SemiBold"/>
            
            <TextBlock 
                Grid.Column="1" 
                Text="PowerInsighter" 
                FontSize="24" 
                FontWeight="Bold" 
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#0078D4"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1" 
                Background="#F0F0F0" 
                CornerRadius="4" 
                Padding="10,8"
                Margin="0,10,0,10">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="13"/>
        </Border>

        <!-- Main Content Area with Tabs -->
        <TabControl Grid.Row="2" 
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Resources>
                <!-- Modern TabItem Style -->
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="16,10"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                    <Setter Property="Foreground" Value="#666666"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid x:Name="Root">
                                    <Border x:Name="Border"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="1,1,1,0"
                                            BorderBrush="Transparent"
                                            CornerRadius="6,6,0,0"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="0,0,0,-1">
                                        <ContentPresenter x:Name="ContentSite"
                                                          ContentSource="Header"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="BottomIndicator"
                                            Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="Transparent"
                                            CornerRadius="2,2,0,0"
                                            Margin="8,0,8,-1"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#0078D4"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter TargetName="Border" Property="Background" Value="White"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#E0E0E0"/>
                                        <Setter TargetName="BottomIndicator" Property="Background" Value="#0078D4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="White"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            
            <!-- TabControl Panel Template for horizontal tabs with border -->
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Tab Header Panel with Border -->
                        <Border Grid.Row="0" 
                                Background="#FAFAFA" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="8,8,0,0"
                                Padding="4,4,4,0">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      Background="Transparent"/>
                        </Border>
                        
                        <!-- Content Panel -->
                        <Border Grid.Row="1" 
                                Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1,0,1,1" 
                                CornerRadius="0,0,8,8">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            
            <!-- Model Overview Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Model Overview" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Model Overview" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Row 1 -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Tables" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.TableCount}" FontSize="28" FontWeight="Bold" Foreground="#0078D4"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Measures" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.MeasureCount}" FontSize="28" FontWeight="Bold" Foreground="#107C10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Columns" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.ColumnCount}" FontSize="28" FontWeight="Bold" Foreground="#5C2D91"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Relationships" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.RelationshipCount}" FontSize="28" FontWeight="Bold" Foreground="#E81123"/>
                                </StackPanel>
                                
                                <!-- Row 2 -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Calculated Columns" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.CalculatedColumnCount}" FontSize="28" FontWeight="Bold" Foreground="#FF8C00"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Calculated Tables" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.CalculatedTableCount}" FontSize="28" FontWeight="Bold" Foreground="#008080"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Compatibility Level" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.CompatibilityLevel}" FontSize="28" FontWeight="Bold" Foreground="#666666"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Last Refresh" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.LastRefresh, StringFormat='{}{0:g}'}" FontSize="16" FontWeight="SemiBold" Foreground="#666666"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="Model Name" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding ModelOverview.ModelName}" FontSize="16" Foreground="#333"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Measures Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📐" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Measures" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    
                    <!-- Header with Title, Count, Search Bar, and Settings on same row -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Title and Count on the Left -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Measures" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Background="#E8F4FD" CornerRadius="12" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#0078D4">
                                    <Run Text="{Binding FilteredMeasures.Count, Mode=OneWay}"/>
                                    <Run Text=" of "/>
                                    <Run Text="{Binding Measures.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        
                        <!-- Search Bar on the Right -->
                        <Border Grid.Column="2" 
                                Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="10,6"
                                Width="300"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                           Text="🔍" 
                                           FontSize="14" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,0"/>
                                
                                <TextBox Grid.Column="1"
                                         Text="{Binding MeasuresSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         Background="Transparent">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Search measures..." 
                                                                              Foreground="#999" 
                                                                              FontSize="13"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" 
                                        Content="✕" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        FontSize="12"
                                        Foreground="#999"
                                        Cursor="Hand"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding MeasuresSearchText, Converter={StaticResource StringToVisibilityConverter}}"
                                        Command="{Binding ClearMeasuresSearchCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#333"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <!-- Settings Button (Outside Search Bar) -->
                        <ToggleButton Grid.Column="3" 
                                      x:Name="SettingsButton"
                                      IsChecked="{Binding IsColumnSettingsOpen, Mode=TwoWay}"
                                      Background="Transparent" 
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Padding="8,4"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      ToolTip="Column Settings">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4">
                                                    <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="#E8F4FD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        
                        <!-- Export Button -->
                        <Button Grid.Column="4" 
                                Command="{Binding ExportMeasuresCommand}"
                                Background="Transparent" 
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="Export to Excel">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ButtonBorder" 
                                                        Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📥" FontSize="16" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Export" FontSize="12" FontWeight="SemiBold" 
                                                                   Foreground="#107C10" VerticalAlignment="Center" 
                                                                   Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#E8F5E9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#C8E6C9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Column Settings Popup -->
                        <Popup IsOpen="{Binding IsColumnSettingsOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=SettingsButton}"
                               Placement="Left"
                               HorizontalOffset="35"
                               VerticalOffset="30"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               DataContext="{Binding}">
                            <Border Background="White" 
                                    BorderBrush="#E0E0E0" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="200"
                                    MaxHeight="400">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Visible Columns" 
                                                   FontWeight="Bold" 
                                                   FontSize="13" 
                                                   Margin="0,0,0,10"
                                                   Foreground="#333"/>
                                        
                                        <CheckBox Content="Name" 
                                                  IsChecked="{Binding ShowNameColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Table" 
                                                  IsChecked="{Binding ShowTableColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Expression" 
                                                  IsChecked="{Binding ShowExpressionColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Description" 
                                                  IsChecked="{Binding ShowDescriptionColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Format String" 
                                                  IsChecked="{Binding ShowFormatStringColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Visibility" 
                                                  IsChecked="{Binding ShowIsHiddenColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Display Folder" 
                                                  IsChecked="{Binding ShowDisplayFolderColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Data Type" 
                                                  IsChecked="{Binding ShowDataTypeColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Detail Rows" 
                                                  IsChecked="{Binding ShowDetailRowsExpressionColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="KPI" 
                                                  IsChecked="{Binding ShowKPIColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="State" 
                                                  IsChecked="{Binding ShowStateColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Error Message" 
                                                  IsChecked="{Binding ShowErrorMessageColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Lineage Tag" 
                                                  IsChecked="{Binding ShowLineageTagColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                        <CheckBox Content="Modified Time" 
                                                  IsChecked="{Binding ShowModifiedTimeColumn, Mode=TwoWay}" 
                                                  Margin="0,3" 
                                                  FontSize="12"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                        
                    </Grid>
                    
                    <!-- Modern DataGrid -->
                    <Border Grid.Row="1" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8"
                            Padding="0">
                        <DataGrid ItemsSource="{Binding FilteredMeasures}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeight="48"
                                  CanUserResizeRows="False"
                                  CanUserResizeColumns="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True">
                            
                            <!-- DataGrid Styles and BindingProxy -->
                            <DataGrid.Resources>
                                <!-- BindingProxy to allow column visibility binding -->
                                <helpers:BindingProxy x:Key="Proxy" Data="{Binding}"/>
                                
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E8F4FD"/>
                                            <Setter Property="Foreground" Value="#000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E8F4FD"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,14"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0" 
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <!-- Sort Arrow -->
                                                        <Path x:Name="SortArrow" 
                                                              Grid.Column="1"
                                                              Visibility="Collapsed"
                                                              Margin="6,0,0,0"
                                                              VerticalAlignment="Center"
                                                              Fill="#666"
                                                              Data="M 0,0 L 4,4 L 8,0 Z"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="SortDirection" Value="Ascending">
                                                        <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="SortArrow" Property="Data" Value="M 0,4 L 4,0 L 8,4 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="SortDirection" Value="Descending">
                                                        <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 4,4 L 8,0 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                
                                <!-- Modern Slim ScrollBar Thumb Style -->
                                <Style x:Key="SlimScrollBarThumb" TargetType="Thumb">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="IsTabStop" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="#C0C0C0"
                                                        CornerRadius="3"
                                                        Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#A0A0A0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#808080"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                
                                <!-- Modern Slim Vertical ScrollBar Style -->
                                <Style x:Key="SlimVerticalScrollBar" TargetType="ScrollBar">
                                    <Setter Property="Width" Value="8"/>
                                    <Setter Property="MinWidth" Value="8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid x:Name="GridRoot" Background="{TemplateBinding Background}">
                                                    <Border Background="#F5F5F5" CornerRadius="4" Margin="1">
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="GridRoot" Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                
                                <!-- Modern Slim Horizontal ScrollBar Style -->
                                <Style x:Key="SlimHorizontalScrollBar" TargetType="ScrollBar">
                                    <Setter Property="Height" Value="8"/>
                                    <Setter Property="MinHeight" Value="8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid x:Name="GridRoot" Background="{TemplateBinding Background}">
                                                    <Border Background="#F5F5F5" CornerRadius="4" Margin="1">
                                                        <Track x:Name="PART_Track">
                                                            <Track.Thumb>
                                                                <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="GridRoot" Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                
                                <!-- Apply ScrollBar styles to ScrollViewer -->
                                <Style TargetType="ScrollBar">
                                    <Style.Triggers>
                                        <Trigger Property="Orientation" Value="Vertical">
                                            <Setter Property="Width" Value="8"/>
                                            <Setter Property="MinWidth" Value="8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid x:Name="GridRoot" Background="Transparent">
                                                            <Border Background="#F5F5F5" CornerRadius="4" Margin="1">
                                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                                    <Track.Thumb>
                                                                        <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                                                                    </Track.Thumb>
                                                                </Track>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="GridRoot" Property="Background" Value="#F0F0F0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Height" Value="8"/>
                                            <Setter Property="MinHeight" Value="8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid x:Name="GridRoot" Background="Transparent">
                                                            <Border Background="#F5F5F5" CornerRadius="4" Margin="1">
                                                                <Track x:Name="PART_Track">
                                                                    <Track.Thumb>
                                                                        <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                                                                    </Track.Thumb>
                                                                </Track>
                                                            </Border>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="GridRoot" Property="Background" Value="#F0F0F0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            
                            <DataGrid.Columns>
                                <!-- S.No Column (Row Number) -->
                                <DataGridTemplateColumn Header="S.NO" 
                                                        Width="60" 
                                                        MinWidth="50"
                                                        MaxWidth="80"
                                                        IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="#888"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource RowNumberConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.FilteredMeasures" 
                                                                 RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Name Column -->
                            <DataGridTemplateColumn Header="NAME" 
                                                    Width="180" 
                                                    MinWidth="100"
                                                    MaxWidth="400"
                                                    SortMemberPath="Name"
                                                    Visibility="{Binding Data.ShowNameColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#107C10" Width="4" Height="20" CornerRadius="2" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Table Column -->
                                <DataGridTemplateColumn Header="TABLE" 
                                                        Width="130" 
                                                        MinWidth="80"
                                                        MaxWidth="300"
                                                        SortMemberPath="Table"
                                                        Visibility="{Binding Data.ShowTableColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F0F0F0" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Table}" FontSize="12" Foreground="#666"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Expression Column -->
                                <DataGridTemplateColumn Header="EXPRESSION" 
                                                        Width="350" 
                                                        MinWidth="200"
                                                        MaxWidth="800"
                                                        SortMemberPath="Expression"
                                                        Visibility="{Binding Data.ShowExpressionColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Expression}" 
                                                           FontFamily="Consolas" 
                                                           FontSize="12" 
                                                           Foreground="#5C2D91"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding Expression}"/>
                                                
                                                <!-- Action Buttons -->
                                                <StackPanel Grid.Column="1" 
                                                            Orientation="Horizontal" 
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <!-- View DAX Button -->
                                                    <Button Command="{Binding DataContext.ViewDaxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Padding="4"
                                                            ToolTip="View DAX Expression"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="BtnBorder" 
                                                                                    Background="Transparent" 
                                                                                    CornerRadius="4"
                                                                                    Padding="4">
                                                                                <TextBlock Text="👁" FontSize="14" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E3F2FD"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsPressed" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#BBDEFB"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    
                                                    <!-- Copy DAX Button -->
                                                    <Button Command="{Binding DataContext.CopyDaxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Padding="4"
                                                            ToolTip="Copy DAX Expression">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="BtnBorder" 
                                                                                    Background="Transparent" 
                                                                                    CornerRadius="4"
                                                                                    Padding="4">
                                                                                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E8F5E9"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsPressed" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#C8E6C9"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Description Column -->
                                <DataGridTemplateColumn Header="DESCRIPTION" 
                                                        Width="180" 
                                                        MinWidth="100"
                                                        MaxWidth="500"
                                                        SortMemberPath="Description"
                                                        Visibility="{Binding Data.ShowDescriptionColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" 
                                                       FontSize="12" 
                                                       Foreground="#666"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Description}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Format Column -->
                                <DataGridTemplateColumn Header="FORMAT" 
                                                        Width="100" 
                                                        MinWidth="60"
                                                        MaxWidth="200"
                                                        SortMemberPath="FormatString"
                                                        Visibility="{Binding Data.ShowFormatStringColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FormatString}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="11" 
                                                       Foreground="#888"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Hidden Column -->
                                <DataGridTemplateColumn Header="VISIBILITY" 
                                                        Width="90"
                                                        MinWidth="70"
                                                        MaxWidth="150"
                                                        Visibility="{Binding Data.ShowIsHiddenColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Visible"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Text" Value="Hidden"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Display Folder Column -->
                                <DataGridTemplateColumn Header="FOLDER" 
                                                        Width="120" 
                                                        MinWidth="80"
                                                        MaxWidth="300"
                                                        SortMemberPath="DisplayFolder"
                                                        Visibility="{Binding Data.ShowDisplayFolderColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📁" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayFolder}" 
                                                           FontSize="12" 
                                                           Foreground="#666"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Data Type Column -->
                                <DataGridTemplateColumn Header="DATA TYPE" 
                                                        Width="90" 
                                                        MinWidth="70"
                                                        MaxWidth="200"
                                                        SortMemberPath="DataType"
                                                        Visibility="{Binding Data.ShowDataTypeColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#E3F2FD" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding DataType}" FontSize="11" Foreground="#1565C0" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Detail Rows Expression Column -->
                                <DataGridTemplateColumn Header="DETAIL ROWS" 
                                                        Width="200" 
                                                        MinWidth="100"
                                                        MaxWidth="500"
                                                        SortMemberPath="DetailRowsExpression"
                                                        Visibility="{Binding Data.ShowDetailRowsExpressionColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DetailRowsExpression}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="11" 
                                                       Foreground="#666"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding DetailRowsExpression}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- KPI Column -->
                                <DataGridTemplateColumn Header="KPI" 
                                                        Width="100" 
                                                        MinWidth="70"
                                                        MaxWidth="250"
                                                        SortMemberPath="KPI"
                                                        Visibility="{Binding Data.ShowKPIColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#FCE4EC" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left"
                                                    Visibility="{Binding KPI, Converter={StaticResource StringToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📊" FontSize="10" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding KPI}" FontSize="11" Foreground="#C2185B"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- State Column -->
                                <DataGridTemplateColumn Header="STATE" 
                                                        Width="100" 
                                                        MinWidth="70"
                                                        MaxWidth="200"
                                                        SortMemberPath="State"
                                                        Visibility="{Binding Data.ShowStateColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="NoData">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding State}"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="NoData">
                                                                    <Setter Property="Foreground" Value="#EF6C00"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Error Message Column -->
                                <DataGridTemplateColumn Header="ERROR" 
                                                        Width="200" 
                                                        MinWidth="100"
                                                        MaxWidth="500"
                                                        SortMemberPath="ErrorMessage"
                                                        Visibility="{Binding Data.ShowErrorMessageColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ErrorMessage}" 
                                                       FontSize="11" 
                                                       Foreground="#C62828"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ErrorMessage}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Lineage Tag Column -->
                                <DataGridTemplateColumn Header="LINEAGE TAG" 
                                                        Width="150" 
                                                        MinWidth="80"
                                                        MaxWidth="400"
                                                        SortMemberPath="LineageTag"
                                                        Visibility="{Binding Data.ShowLineageTagColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LineageTag}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="10" 
                                                       Foreground="#888"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding LineageTag}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Modified Time Column -->
                                <DataGridTemplateColumn Header="MODIFIED" 
                                                        Width="140" 
                                                        MinWidth="100"
                                                        MaxWidth="250"
                                                        SortMemberPath="ModifiedTime"
                                                        Visibility="{Binding Data.ShowModifiedTimeColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🕐" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModifiedTime, StringFormat='{}{0:g}'}" 
                                                           FontSize="11" 
                                                           Foreground="#666"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Columns Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Columns" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header with Title, Count, Search Bar, and Settings on same row -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Title and Count on the Left -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Columns" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Background="#F3E5F5" CornerRadius="12" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#5C2D91">
                                    <Run Text="{Binding FilteredColumns.Count, Mode=OneWay}"/>
                                    <Run Text=" of "/>
                                    <Run Text="{Binding Columns.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        
                        <!-- Search Bar on the Right -->
                        <Border Grid.Column="2" 
                                Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="10,6"
                                Width="300"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                           Text="🔍" 
                                           FontSize="14" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,0"/>
                                
                                <TextBox Grid.Column="1"
                                         Text="{Binding ColumnsSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         Background="Transparent">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Search columns..." 
                                                                              Foreground="#999" 
                                                                              FontSize="13"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" 
                                        Content="✕" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        FontSize="12"
                                        Foreground="#999"
                                        Cursor="Hand"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding ColumnsSearchText, Converter={StaticResource StringToVisibilityConverter}}"
                                        Command="{Binding ClearColumnsSearchCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#333"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <!-- Settings Button -->
                        <ToggleButton Grid.Column="3" 
                                      x:Name="ColumnsSettingsButton"
                                      IsChecked="{Binding IsColumnsSettingsOpen, Mode=TwoWay}"
                                      Background="Transparent" 
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Padding="8,4"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      ToolTip="Column Settings">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4">
                                                    <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="#F3E5F5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        
                        <!-- Export Button -->
                        <Button Grid.Column="4" 
                                Command="{Binding ExportColumnsCommand}"
                                Background="Transparent" 
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="Export to Excel">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ButtonBorder" 
                                                        Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📥" FontSize="16" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Export" FontSize="12" FontWeight="SemiBold" 
                                                                   Foreground="#5C2D91" VerticalAlignment="Center" 
                                                                   Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#F3E5F5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#E1BEE7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Column Settings Popup -->
                        <Popup IsOpen="{Binding IsColumnsSettingsOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=ColumnsSettingsButton}"
                               Placement="Left"
                               HorizontalOffset="35"
                               VerticalOffset="30"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               DataContext="{Binding}">
                            <Border Background="White" 
                                    BorderBrush="#E0E0E0" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="220"
                                    MaxHeight="500">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Visible Columns" 
                                                   FontWeight="Bold" 
                                                   FontSize="13" 
                                                   Margin="0,0,0,10"
                                                   Foreground="#333"/>
                                        
                                        <!-- Main Columns -->
                                        <TextBlock Text="Main" FontWeight="SemiBold" FontSize="11" Foreground="#5C2D91" Margin="0,0,0,5"/>
                                        <CheckBox Content="Name" IsChecked="{Binding ShowColNameColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Table" IsChecked="{Binding ShowColTableColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Data Type" IsChecked="{Binding ShowColDataTypeColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Is Calculated" IsChecked="{Binding ShowColIsCalculatedColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Expression" IsChecked="{Binding ShowColExpressionColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Visibility" IsChecked="{Binding ShowColIsHiddenColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Description" IsChecked="{Binding ShowColDescriptionColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Display Folder" IsChecked="{Binding ShowColDisplayFolderColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Format String" IsChecked="{Binding ShowColFormatStringColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        
                                        <!-- Advanced Columns -->
                                        <TextBlock Text="Advanced" FontWeight="SemiBold" FontSize="11" Foreground="#5C2D91" Margin="0,12,0,5"/>
                                        <CheckBox Content="Sort By Column" IsChecked="{Binding ShowColSortByColumnColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Is Unique" IsChecked="{Binding ShowColIsUniqueColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Is Nullable" IsChecked="{Binding ShowColIsNullableColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Is Key" IsChecked="{Binding ShowColIsKeyColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Source Column" IsChecked="{Binding ShowColSourceColumnColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Data Category" IsChecked="{Binding ShowColDataCategoryColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Available In MDX" IsChecked="{Binding ShowColIsAvailableInMDXColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="State" IsChecked="{Binding ShowColStateColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Error Message" IsChecked="{Binding ShowColErrorMessageColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Modified Time" IsChecked="{Binding ShowColModifiedTimeColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Lineage Tag" IsChecked="{Binding ShowColLineageTagColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Summarize By" IsChecked="{Binding ShowColSummarizeByColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Encoding" IsChecked="{Binding ShowColEncodingColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    
                    <!-- Modern DataGrid -->
                    <Border Grid.Row="1" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8"
                            Padding="0">
                        <DataGrid ItemsSource="{Binding FilteredColumns}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeight="48"
                                  CanUserResizeRows="False"
                                  CanUserResizeColumns="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True">
                            
                            <DataGrid.Resources>
                                <helpers:BindingProxy x:Key="ColProxy" Data="{Binding}"/>
                                
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#F3E5F5"/>
                                            <Setter Property="Foreground" Value="#000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#F3E5F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,14"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0" 
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <Path x:Name="SortArrow" 
                                                              Grid.Column="1"
                                                              Visibility="Collapsed"
                                                              Margin="6,0,0,0"
                                                              VerticalAlignment="Center"
                                                              Fill="#666"
                                                              Data="M 0,0 L 4,4 L 8,0 Z"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="SortDirection" Value="Ascending">
                                                        <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="SortArrow" Property="Data" Value="M 0,4 L 4,0 L 8,4 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="SortDirection" Value="Descending">
                                                        <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 4,4 L 8,0 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            
                            <DataGrid.Columns>
                                <!-- S.No Column -->
                                <DataGridTemplateColumn Header="S.NO" Width="60" MinWidth="50" MaxWidth="80" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontWeight="SemiBold" Foreground="#888" HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource RowNumberConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.FilteredColumns" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Name Column -->
                                <DataGridTemplateColumn Header="NAME" Width="180" MinWidth="100" MaxWidth="400" SortMemberPath="Name"
                                                        Visibility="{Binding Data.ShowColNameColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#5C2D91" Width="4" Height="20" CornerRadius="2" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Table Column -->
                                <DataGridTemplateColumn Header="TABLE" Width="130" MinWidth="80" MaxWidth="300" SortMemberPath="Table"
                                                        Visibility="{Binding Data.ShowColTableColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F0F0F0" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Table}" FontSize="12" Foreground="#666"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Data Type Column -->
                                <DataGridTemplateColumn Header="DATA TYPE" Width="100" MinWidth="70" MaxWidth="200" SortMemberPath="DataType"
                                                        Visibility="{Binding Data.ShowColDataTypeColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#E3F2FD" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding DataType}" FontSize="11" Foreground="#1565C0" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Is Calculated Column -->
                                <DataGridTemplateColumn Header="CALCULATED" Width="100" MinWidth="80" MaxWidth="150"
                                                        Visibility="{Binding Data.ShowColIsCalculatedColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F5F5F5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCalculated}" Value="True">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="No"/>
                                                            <Setter Property="Foreground" Value="#888"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCalculated}" Value="True">
                                                                    <Setter Property="Text" Value="Yes"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Expression Column -->
                                <DataGridTemplateColumn Header="EXPRESSION" Width="350" MinWidth="200" MaxWidth="800" SortMemberPath="Expression"
                                                        Visibility="{Binding Data.ShowColExpressionColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Expression}" 
                                                           FontFamily="Consolas" 
                                                           FontSize="12" 
                                                           Foreground="#5C2D91"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding Expression}"/>
                                                
                                                <!-- Action Buttons (only visible when there's an expression) -->
                                                <StackPanel Grid.Column="1" 
                                                            Orientation="Horizontal" 
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding Expression, Converter={StaticResource StringToVisibilityConverter}}">
                                                    <!-- View Expression Button -->
                                                    <Button Command="{Binding DataContext.ViewColumnExpressionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Padding="4"
                                                            ToolTip="View Expression"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4" Padding="4">
                                                                                <TextBlock Text="👁" FontSize="14" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#F3E5F5"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsPressed" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E1BEE7"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    
                                                    <!-- Copy Expression Button -->
                                                    <Button Command="{Binding DataContext.CopyColumnExpressionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Padding="4"
                                                            ToolTip="Copy Expression">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4" Padding="4">
                                                                                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E8F5E9"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsPressed" Value="True">
                                                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#C8E6C9"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Visibility Column -->
                                <DataGridTemplateColumn Header="VISIBILITY" Width="90" MinWidth="70" MaxWidth="150"
                                                        Visibility="{Binding Data.ShowColIsHiddenColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Visible"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Text" Value="Hidden"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Description Column -->
                                <DataGridTemplateColumn Header="DESCRIPTION" Width="180" MinWidth="100" MaxWidth="500" SortMemberPath="Description"
                                                        Visibility="{Binding Data.ShowColDescriptionColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#666" TextTrimming="CharacterEllipsis" ToolTip="{Binding Description}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Display Folder Column -->
                                <DataGridTemplateColumn Header="FOLDER" Width="120" MinWidth="80" MaxWidth="300" SortMemberPath="DisplayFolder"
                                                        Visibility="{Binding Data.ShowColDisplayFolderColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📁" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayFolder}" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Format String Column -->
                                <DataGridTemplateColumn Header="FORMAT" Width="100" MinWidth="60" MaxWidth="200" SortMemberPath="FormatString"
                                                        Visibility="{Binding Data.ShowColFormatStringColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FormatString}" FontFamily="Consolas" FontSize="11" Foreground="#888"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Sort By Column -->
                                <DataGridTemplateColumn Header="SORT BY" Width="120" MinWidth="80" MaxWidth="250" SortMemberPath="SortByColumn"
                                                        Visibility="{Binding Data.ShowColSortByColumnColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SortByColumn}" FontSize="12" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Is Unique Column -->
                                <DataGridTemplateColumn Header="UNIQUE" Width="80" MinWidth="60" MaxWidth="120"
                                                        Visibility="{Binding Data.ShowColIsUniqueColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11" Foreground="#666" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnique}" Value="True">
                                                                <Setter Property="Text" Value="Yes"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Is Nullable Column -->
                                <DataGridTemplateColumn Header="NULLABLE" Width="80" MinWidth="60" MaxWidth="120"
                                                        Visibility="{Binding Data.ShowColIsNullableColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11" Foreground="#666" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNullable}" Value="True">
                                                                <Setter Property="Text" Value="Yes"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Is Key Column -->
                                <DataGridTemplateColumn Header="KEY" Width="70" MinWidth="50" MaxWidth="100"
                                                        Visibility="{Binding Data.ShowColIsKeyColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center"
                                                    Visibility="{Binding IsKey, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="🔑" FontSize="12"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Source Column -->
                                <DataGridTemplateColumn Header="SOURCE" Width="150" MinWidth="80" MaxWidth="300" SortMemberPath="SourceColumn"
                                                        Visibility="{Binding Data.ShowColSourceColumnColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SourceColumn}" FontFamily="Consolas" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis" ToolTip="{Binding SourceColumn}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Data Category Column -->
                                <DataGridTemplateColumn Header="CATEGORY" Width="100" MinWidth="70" MaxWidth="200" SortMemberPath="DataCategory"
                                                        Visibility="{Binding Data.ShowColDataCategoryColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DataCategory}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Available In MDX Column -->
                                <DataGridTemplateColumn Header="IN MDX" Width="80" MinWidth="60" MaxWidth="120"
                                                        Visibility="{Binding Data.ShowColIsAvailableInMDXColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11" Foreground="#666" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailableInMDX}" Value="True">
                                                                <Setter Property="Text" Value="Yes"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- State Column -->
                                <DataGridTemplateColumn Header="STATE" Width="100" MinWidth="70" MaxWidth="200" SortMemberPath="State"
                                                        Visibility="{Binding Data.ShowColStateColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="NoData">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding State}"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="NoData">
                                                                    <Setter Property="Foreground" Value="#EF6C00"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Error Message Column -->
                                <DataGridTemplateColumn Header="ERROR" Width="200" MinWidth="100" MaxWidth="500" SortMemberPath="ErrorMessage"
                                                        Visibility="{Binding Data.ShowColErrorMessageColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ErrorMessage}" FontSize="11" Foreground="#C62828" TextTrimming="CharacterEllipsis" ToolTip="{Binding ErrorMessage}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Modified Time Column -->
                                <DataGridTemplateColumn Header="MODIFIED" Width="140" MinWidth="100" MaxWidth="250" SortMemberPath="ModifiedTime"
                                                        Visibility="{Binding Data.ShowColModifiedTimeColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🕐" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModifiedTime, StringFormat='{}{0:g}'}" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Lineage Tag Column -->
                                <DataGridTemplateColumn Header="LINEAGE TAG" Width="150" MinWidth="80" MaxWidth="400" SortMemberPath="LineageTag"
                                                        Visibility="{Binding Data.ShowColLineageTagColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LineageTag}" FontFamily="Consolas" FontSize="10" Foreground="#888" TextTrimming="CharacterEllipsis" ToolTip="{Binding LineageTag}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Summarize By Column -->
                                <DataGridTemplateColumn Header="SUMMARIZE" Width="100" MinWidth="70" MaxWidth="200" SortMemberPath="SummarizeBy"
                                                        Visibility="{Binding Data.ShowColSummarizeByColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SummarizeBy}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Encoding Column -->
                                <DataGridTemplateColumn Header="ENCODING" Width="100" MinWidth="70" MaxWidth="200" SortMemberPath="Encoding"
                                                        Visibility="{Binding Data.ShowColEncodingColumn, Source={StaticResource ColProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Encoding}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Relationships Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Relationships" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header with Title, Count, Search Bar, and Settings on same row -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Title and Count on the Left -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Relationships" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Background="#FFEBEE" CornerRadius="12" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E81123">
                                    <Run Text="{Binding FilteredRelationships.Count, Mode=OneWay}"/>
                                    <Run Text=" of "/>
                                    <Run Text="{Binding Relationships.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        
                        <!-- Search Bar on the Right -->
                        <Border Grid.Column="2" 
                                Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="10,6"
                                Width="300"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                           Text="🔍" 
                                           FontSize="14" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,0"/>
                                
                                <TextBox Grid.Column="1"
                                         Text="{Binding RelationshipsSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         FontSize="13"
                                         VerticalAlignment="Center"
                                         Background="Transparent">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Search relationships..." 
                                                                              Foreground="#999" 
                                                                              FontSize="13"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <Button Grid.Column="2" 
                                        Content="✕" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        FontSize="12"
                                        Foreground="#999"
                                        Cursor="Hand"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding RelationshipsSearchText, Converter={StaticResource StringToVisibilityConverter}}"
                                        Command="{Binding ClearRelationshipsSearchCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#333"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <!-- Settings Button -->
                        <ToggleButton Grid.Column="3" 
                                      x:Name="RelationshipsSettingsButton"
                                      IsChecked="{Binding IsRelationshipsSettingsOpen, Mode=TwoWay}"
                                      Background="Transparent" 
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Padding="8,4"
                                      Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      ToolTip="Column Settings">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4">
                                                    <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        
                        <!-- Export Button -->
                        <Button Grid.Column="4" 
                                Command="{Binding ExportRelationshipsCommand}"
                                Background="Transparent" 
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="Export to Excel">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ButtonBorder" 
                                                        Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}"
                                                        CornerRadius="4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📥" FontSize="16" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Export" FontSize="12" FontWeight="SemiBold" 
                                                                   Foreground="#E81123" VerticalAlignment="Center" 
                                                                   Margin="5,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#FFEBEE"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#FFCDD2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Column Settings Popup -->
                        <Popup IsOpen="{Binding IsRelationshipsSettingsOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=RelationshipsSettingsButton}"
                               Placement="Left"
                               HorizontalOffset="35"
                               VerticalOffset="30"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               DataContext="{Binding}">
                            <Border Background="White" 
                                    BorderBrush="#E0E0E0" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="220"
                                    MaxHeight="500">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Visible Columns" 
                                                   FontWeight="Bold" 
                                                   FontSize="13" 
                                                   Margin="0,0,0,10"
                                                   Foreground="#333"/>
                                        
                                        <!-- Main Columns -->
                                        <TextBlock Text="Main" FontWeight="SemiBold" FontSize="11" Foreground="#E81123" Margin="0,0,0,5"/>
                                        <CheckBox Content="Name" IsChecked="{Binding ShowRelNameColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="From Table" IsChecked="{Binding ShowRelFromTableColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="From Column" IsChecked="{Binding ShowRelFromColumnColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="To Table" IsChecked="{Binding ShowRelToTableColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="To Column" IsChecked="{Binding ShowRelToColumnColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Cardinality" IsChecked="{Binding ShowRelCardinalityColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Cross Filter" IsChecked="{Binding ShowRelCrossFilterColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Is Active" IsChecked="{Binding ShowRelIsActiveColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        
                                        <!-- Advanced Columns -->
                                        <TextBlock Text="Advanced" FontWeight="SemiBold" FontSize="11" Foreground="#E81123" Margin="0,12,0,5"/>
                                        <CheckBox Content="From Cardinality" IsChecked="{Binding ShowRelFromCardinalityColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="To Cardinality" IsChecked="{Binding ShowRelToCardinalityColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Security Filter" IsChecked="{Binding ShowRelSecurityFilterColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Join On Date" IsChecked="{Binding ShowRelJoinOnDateColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Rely On Ref. Integrity" IsChecked="{Binding ShowRelRelyOnRefIntColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="State" IsChecked="{Binding ShowRelStateColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                        <CheckBox Content="Modified Time" IsChecked="{Binding ShowRelModifiedTimeColumn, Mode=TwoWay}" Margin="0,3" FontSize="12"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    
                    <!-- Modern DataGrid -->
                    <Border Grid.Row="1" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8"
                            Padding="0">
                        <DataGrid ItemsSource="{Binding FilteredRelationships}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  RowHeight="48"
                                  CanUserResizeRows="False"
                                  CanUserResizeColumns="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True">
                            
                            <DataGrid.Resources>
                                <helpers:BindingProxy x:Key="RelProxy" Data="{Binding}"/>
                                
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                            <Setter Property="Foreground" Value="#000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,14"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridColumnHeader">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0" 
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <Path x:Name="SortArrow" 
                                                              Grid.Column="1"
                                                              Visibility="Collapsed"
                                                              Margin="6,0,0,0"
                                                              VerticalAlignment="Center"
                                                              Fill="#666"
                                                              Data="M 0,0 L 4,4 L 8,0 Z"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="SortDirection" Value="Ascending">
                                                        <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="SortArrow" Property="Data" Value="M 0,4 L 4,0 L 8,4 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="SortDirection" Value="Descending">
                                                        <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 4,4 L 8,0 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            
                            <DataGrid.Columns>
                                <!-- S.No Column -->
                                <DataGridTemplateColumn Header="S.NO" Width="60" MinWidth="50" MaxWidth="80" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontWeight="SemiBold" Foreground="#888" HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource RowNumberConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.FilteredRelationships" RelativeSource="{RelativeSource AncestorType=DataGrid}"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Name Column -->
                                <DataGridTemplateColumn Header="NAME" Width="150" MinWidth="100" MaxWidth="300" SortMemberPath="Name"
                                                        Visibility="{Binding Data.ShowRelNameColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#E81123" Width="4" Height="20" CornerRadius="2" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- From Table Column -->
                                <DataGridTemplateColumn Header="FROM TABLE" Width="130" MinWidth="80" MaxWidth="250" SortMemberPath="FromTable"
                                                        Visibility="{Binding Data.ShowRelFromTableColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#E3F2FD" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding FromTable}" FontSize="12" Foreground="#1565C0" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- From Column Column -->
                                <DataGridTemplateColumn Header="FROM COLUMN" Width="120" MinWidth="80" MaxWidth="250" SortMemberPath="FromColumn"
                                                        Visibility="{Binding Data.ShowRelFromColumnColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FromColumn}" FontSize="12" Foreground="#333"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Arrow/Direction Indicator -->
                                <DataGridTemplateColumn Header="" Width="40" MinWidth="40" MaxWidth="40" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="→" FontSize="16" FontWeight="Bold" Foreground="#E81123" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- To Table Column -->
                                <DataGridTemplateColumn Header="TO TABLE" Width="130" MinWidth="80" MaxWidth="250" SortMemberPath="ToTable"
                                                        Visibility="{Binding Data.ShowRelToTableColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF3E0" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ToTable}" FontSize="12" Foreground="#E65100" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- To Column Column -->
                                <DataGridTemplateColumn Header="TO COLUMN" Width="120" MinWidth="80" MaxWidth="250" SortMemberPath="ToColumn"
                                                        Visibility="{Binding Data.ShowRelToColumnColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ToColumn}" FontSize="12" Foreground="#333"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Cardinality Column -->
                                <DataGridTemplateColumn Header="CARDINALITY" Width="130" MinWidth="100" MaxWidth="200" SortMemberPath="Cardinality"
                                                        Visibility="{Binding Data.ShowRelCardinalityColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F3E5F5" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Cardinality}" FontSize="11" Foreground="#7B1FA2" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Cross Filter Column -->
                                <DataGridTemplateColumn Header="CROSS FILTER" Width="120" MinWidth="90" MaxWidth="200" SortMemberPath="CrossFilterDirection"
                                                        Visibility="{Binding Data.ShowRelCrossFilterColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CrossFilterDirection}" Value="Both">
                                                                <Setter Property="Background" Value="#E3F2FD"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding CrossFilterDirection}"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CrossFilterDirection}" Value="Both">
                                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Is Active Column -->
                                <DataGridTemplateColumn Header="STATUS" Width="90" MinWidth="70" MaxWidth="130"
                                                        Visibility="{Binding Data.ShowRelIsActiveColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Active"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Text" Value="Inactive"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- From Cardinality Column (Advanced) -->
                                <DataGridTemplateColumn Header="FROM CARD." Width="100" MinWidth="70" MaxWidth="150" SortMemberPath="FromCardinality"
                                                        Visibility="{Binding Data.ShowRelFromCardinalityColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FromCardinality}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- To Cardinality Column (Advanced) -->
                                <DataGridTemplateColumn Header="TO CARD." Width="100" MinWidth="70" MaxWidth="150" SortMemberPath="ToCardinality"
                                                        Visibility="{Binding Data.ShowRelToCardinalityColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ToCardinality}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Security Filter Column (Advanced) -->
                                <DataGridTemplateColumn Header="SECURITY FILTER" Width="130" MinWidth="90" MaxWidth="200" SortMemberPath="SecurityFilteringBehavior"
                                                        Visibility="{Binding Data.ShowRelSecurityFilterColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SecurityFilteringBehavior}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Join On Date Column (Advanced) -->
                                <DataGridTemplateColumn Header="JOIN ON DATE" Width="120" MinWidth="80" MaxWidth="180" SortMemberPath="JoinOnDateBehavior"
                                                        Visibility="{Binding Data.ShowRelJoinOnDateColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding JoinOnDateBehavior}" FontSize="11" Foreground="#666"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Rely On Ref Integrity Column (Advanced) -->
                                <DataGridTemplateColumn Header="REF. INTEGRITY" Width="110" MinWidth="80" MaxWidth="150"
                                                        Visibility="{Binding Data.ShowRelRelyOnRefIntColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11" Foreground="#666" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelyOnReferentialIntegrity}" Value="True">
                                                                <Setter Property="Text" Value="Yes"/>
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- State Column (Advanced) -->
                                <DataGridTemplateColumn Header="STATE" Width="100" MinWidth="70" MaxWidth="150" SortMemberPath="State"
                                                        Visibility="{Binding Data.ShowRelStateColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding State}"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Modified Time Column (Advanced) -->
                                <DataGridTemplateColumn Header="MODIFIED" Width="140" MinWidth="100" MaxWidth="200" SortMemberPath="ModifiedTime"
                                                        Visibility="{Binding Data.ShowRelModifiedTimeColumn, Source={StaticResource RelProxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🕐" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModifiedTime, StringFormat='{}{0:g}'}" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Dependencies Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Dependencies" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Dependencies" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Dependencies}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Object Name" Binding="{Binding ObjectName}" Width="150"/>
                            <DataGridTextColumn Header="Object Type" Binding="{Binding ObjectType}" Width="120"/>
                            <DataGridTextColumn Header="Depends On" Binding="{Binding DependsOn}" Width="*"/>
                            <DataGridTextColumn Header="Dependency Type" Binding="{Binding DependencyType}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Unused Objects Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Unused Objects" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Unused Objects" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Objects that may be candidates for removal to optimize your model" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding UnusedObjects}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#FFF8E7"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding ObjectType}" Width="120"/>
                            <DataGridTextColumn Header="Table" Binding="{Binding Table}" Width="120"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Impact Analysis Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💥" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Impact Analysis" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Impact Analysis" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Understand the downstream impact of changes to your model objects" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ImpactAnalysis}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Object Name" Binding="{Binding ObjectName}" Width="150"/>
                            <DataGridTextColumn Header="Object Type" Binding="{Binding ObjectType}" Width="100"/>
                            <DataGridTextColumn Header="Impacted Object" Binding="{Binding ImpactedObject}" Width="150"/>
                            <DataGridTextColumn Header="Impact Type" Binding="{Binding ImpactType}" Width="150"/>
                            <DataGridTemplateColumn Header="Severity" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="5,2" CornerRadius="3" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                            <Setter Property="Background" Value="#FFE0E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="High">
                                                            <Setter Property="Background" Value="#FFE8CC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                            <Setter Property="Background" Value="#FFF8CC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Low">
                                                            <Setter Property="Background" Value="#E0FFE0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Severity}" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Welcome Message when not connected -->
        <Border Grid.Row="2" 
                Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                Background="#F5F5F5"
                CornerRadius="8"
                Padding="40">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔌" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Welcome to PowerInsighter" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Connect to a Power BI Desktop instance to analyze your data model" 
                           FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <TextBlock Text="Features:" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="📊 Model Overview - Get a quick summary of your model" Margin="0,5"/>
                    <TextBlock Text="📐 Measures - View all measures and their expressions" Margin="0,5"/>
                    <TextBlock Text="📋 Columns - Explore columns and calculated columns" Margin="0,5"/>
                    <TextBlock Text="🔗 Relationships - Analyze table relationships" Margin="0,5"/>
                    <TextBlock Text="🔄 Dependencies - Understand object dependencies" Margin="0,5"/>
                    <TextBlock Text="⚠️ Unused Objects - Find optimization opportunities" Margin="0,5"/>
                    <TextBlock Text="💥 Impact Analysis - Assess change impacts" Margin="0,5"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- DAX Viewer Popup (Global - works from any tab) -->
        <Popup IsOpen="{Binding IsDaxViewerOpen, Mode=TwoWay}"
               Placement="Center"
               PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
               StaysOpen="True"
               AllowsTransparency="True">
            <Border Background="White" 
                    BorderBrush="#0078D4" 
                    BorderThickness="2" 
                    CornerRadius="12"
                    Width="700"
                    MaxHeight="500">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Background="#0078D4" 
                            CornerRadius="10,10,0,0"
                            Padding="20,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DAX Expression" 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="White"/>
                                <TextBlock Text="{Binding SelectedMeasureName}" 
                                           FontSize="13" 
                                           Foreground="#B3FFFFFF"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- Close Button -->
                            <Button Grid.Column="1"
                                    Command="{Binding CloseDaxViewerCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    VerticalAlignment="Top">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="CloseBorder" 
                                                            Background="Transparent" 
                                                            CornerRadius="4"
                                                            Padding="6">
                                                        <TextBlock Text="✕" 
                                                                   FontSize="16" 
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CloseBorder" Property="Background" Value="#20FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- DAX Content -->
                    <Border Grid.Row="1" 
                            Background="#1E1E1E" 
                            Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="20">
                            <TextBox Text="{Binding SelectedDaxExpression, Mode=OneWay}"
                                     FontFamily="Consolas"
                                     FontSize="14"
                                     Foreground="#D4D4D4"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Disabled"/>
                        </ScrollViewer>
                    </Border>
                    
                    <!-- Footer with Format and Copy Buttons -->
                    <Border Grid.Row="2" 
                            Background="#F5F5F5" 
                            CornerRadius="0,0,10,10"
                            Padding="15,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Press Ctrl+C to copy" 
                                           FontSize="12" 
                                           Foreground="#666"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" • " 
                                           FontSize="12" 
                                           Foreground="#999"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsFormatting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="Formatting..." 
                                           FontSize="12" 
                                           Foreground="#0078D4"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsFormatting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                            
                            <!-- Format Button -->
                            <Button Grid.Column="1"
                                    Command="{Binding FormatDaxCommand}"
                                    Cursor="Hand"
                                    Margin="0,0,10,0"
                                    IsEnabled="{Binding IsFormatting, Converter={StaticResource InverseBooleanConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="FormatBtnBorder" 
                                                            Background="#0078D4" 
                                                            CornerRadius="6"
                                                            Padding="16,8">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="✨" FontSize="14" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Format" 
                                                                       FontSize="13" 
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="FormatBtnBorder" Property="Background" Value="#006CBD"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="FormatBtnBorder" Property="Background" Value="#005A9E"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="FormatBtnBorder" Property="Background" Value="#CCCCCC"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Copy Button -->
                            <Button Grid.Column="2"
                                    Command="{Binding CopyDaxCommand}"
                                    CommandParameter="{Binding SelectedDaxExpression}"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="CopyBtnBorder" 
                                                            Background="#107C10" 
                                                            CornerRadius="6"
                                                            Padding="16,8">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Copy DAX" 
                                                                       FontSize="13" 
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CopyBtnBorder" Property="Background" Value="#0E6B0E"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="CopyBtnBorder" Property="Background" Value="#0C5A0C"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
