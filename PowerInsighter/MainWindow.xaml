<Window x:Class="PowerInsighter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:PowerInsighter"
    xmlns:helpers="clr-namespace:PowerInsighter.Helpers"
    mc:Ignorable="d"
    Title="PowerInsighter - Power BI Model Analyzer" 
    Height="700" 
    Width="1200"
    WindowStartupLocation="CenterScreen">
<Grid Margin="10">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with Connect Button -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button
                Grid.Column="0"
                Width="220"
                Height="40"
                Content="🔌 Connect to Power BI Desktop"
                Command="{Binding ConnectCommand}"
                FontSize="14"
                FontWeight="SemiBold"/>
            
            <TextBlock 
                Grid.Column="1" 
                Text="PowerInsighter" 
                FontSize="24" 
                FontWeight="Bold" 
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="#0078D4"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1" 
                Background="#F0F0F0" 
                CornerRadius="4" 
                Padding="10,8"
                Margin="0,10,0,10">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="13"/>
        </Border>

        <!-- Main Content Area with Tabs -->
        <TabControl Grid.Row="2" 
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
            
            <!-- Model Overview Tab -->
            <TabItem Header="📊 Model Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Model Overview" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Row 1 -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Tables" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.TableCount}" FontSize="28" FontWeight="Bold" Foreground="#0078D4"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Measures" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.MeasureCount}" FontSize="28" FontWeight="Bold" Foreground="#107C10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Columns" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.ColumnCount}" FontSize="28" FontWeight="Bold" Foreground="#5C2D91"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="0" Margin="10">
                                    <TextBlock Text="Relationships" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.RelationshipCount}" FontSize="28" FontWeight="Bold" Foreground="#E81123"/>
                                </StackPanel>
                                
                                <!-- Row 2 -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Calculated Columns" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.CalculatedColumnCount}" FontSize="28" FontWeight="Bold" Foreground="#FF8C00"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Calculated Tables" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.CalculatedTableCount}" FontSize="28" FontWeight="Bold" Foreground="#008080"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Compatibility Level" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.CompatibilityLevel}" FontSize="28" FontWeight="Bold" Foreground="#666666"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="1" Margin="10">
                                    <TextBlock Text="Last Refresh" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelOverview.LastRefresh, StringFormat='{}{0:g}'}" FontSize="16" FontWeight="SemiBold" Foreground="#666666"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="Model Name" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding ModelOverview.ModelName}" FontSize="16" Foreground="#333"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Measures Tab -->
            <TabItem Header="📐 Measures">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header with count -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Measures" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Background="#E8F4FD" CornerRadius="12" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#0078D4">
                                    <Run Text="{Binding FilteredMeasures.Count, Mode=OneWay}"/>
                                    <Run Text=" of "/>
                                    <Run Text="{Binding Measures.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Search Bar with Settings -->
                    <Border Grid.Row="1" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="12,10" 
                            Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="🔍" 
                                       FontSize="16" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,10,0"/>
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding MeasuresSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     Background="Transparent">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="Search measures by name, table, expression..." 
                                                                          Foreground="#999" 
                                                                          FontSize="14"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            
                            <Button Grid.Column="2" 
                                    Content="✕" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    FontSize="14"
                                    Foreground="#999"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding MeasuresSearchText, Converter={StaticResource StringToVisibilityConverter}}"
                                    Command="{Binding ClearMeasuresSearchCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#333"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            
                            <!-- Settings Button with Popup -->
                            <ToggleButton Grid.Column="3" 
                                          x:Name="SettingsButton"
                                          IsChecked="{Binding IsColumnSettingsOpen, Mode=TwoWay}"
                                          Background="Transparent" 
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          Padding="8,4"
                                          VerticalAlignment="Center"
                                          ToolTip="Column Settings">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="4">
                                                        <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F0F0F0"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="#E8F4FD"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            
                            <!-- Column Settings Popup -->
                            <Popup Grid.Column="3"
                                   IsOpen="{Binding IsColumnSettingsOpen, Mode=TwoWay}"
                                   PlacementTarget="{Binding ElementName=SettingsButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="-200"
                                   VerticalOffset="5"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   DataContext="{Binding}">
                                <Border Background="White" 
                                        BorderBrush="#E0E0E0" 
                                        BorderThickness="1" 
                                        CornerRadius="8"
                                        Padding="15"
                                        MinWidth="220"
                                        MaxHeight="450">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Text="Visible Columns" 
                                                       FontWeight="Bold" 
                                                       FontSize="14" 
                                                       Margin="0,0,0,12"
                                                       Foreground="#333"/>
                                            
                                            <!-- Core Properties -->
                                            <TextBlock Text="Core Properties" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="11" 
                                                       Foreground="#666"
                                                       Margin="0,0,0,6"/>
                                            <CheckBox Content="Name" 
                                                      IsChecked="{Binding ShowNameColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Table" 
                                                      IsChecked="{Binding ShowTableColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Expression" 
                                                      IsChecked="{Binding ShowExpressionColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Description" 
                                                      IsChecked="{Binding ShowDescriptionColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Format String" 
                                                      IsChecked="{Binding ShowFormatStringColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Visibility (Hidden)" 
                                                      IsChecked="{Binding ShowIsHiddenColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Display Folder" 
                                                      IsChecked="{Binding ShowDisplayFolderColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Data Type" 
                                                      IsChecked="{Binding ShowDataTypeColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            
                                            <!-- Separator -->
                                            <Separator Margin="0,10"/>
                                            
                                            <!-- Additional Properties -->
                                            <TextBlock Text="Additional Properties" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="11" 
                                                       Foreground="#666"
                                                       Margin="0,4,0,6"/>
                                            <CheckBox Content="Detail Rows Expression" 
                                                      IsChecked="{Binding ShowDetailRowsExpressionColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="KPI" 
                                                      IsChecked="{Binding ShowKPIColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="State" 
                                                      IsChecked="{Binding ShowStateColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Error Message" 
                                                      IsChecked="{Binding ShowErrorMessageColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            <CheckBox Content="Lineage Tag" 
                                                      IsChecked="{Binding ShowLineageTagColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                            
                                            <!-- Separator -->
                                            <Separator Margin="0,10"/>
                                            
                                            <!-- Metadata -->
                                            <TextBlock Text="Metadata" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="11" 
                                                       Foreground="#666"
                                                       Margin="0,4,0,6"/>
                                            <CheckBox Content="Modified Time" 
                                                      IsChecked="{Binding ShowModifiedTimeColumn, Mode=TwoWay}" 
                                                      Margin="0,4" 
                                                      FontSize="13"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    
                    <!-- Modern DataGrid -->
                    <Border Grid.Row="2" 
                            Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8"
                            Padding="0">
                        <DataGrid ItemsSource="{Binding FilteredMeasures}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        Background="Transparent"
                        BorderThickness="0"
                        GridLinesVisibility="None"
                        HeadersVisibility="Column"
                        RowHeight="48"
                        CanUserResizeRows="False"
                        CanUserResizeColumns="True"
                        SelectionMode="Single"
                        SelectionUnit="FullRow"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.CanContentScroll="True">
                            
                            <!-- DataGrid Styles and BindingProxy -->
                            <DataGrid.Resources>
                                <!-- BindingProxy to allow column visibility binding -->
                                <helpers:BindingProxy x:Key="Proxy" Data="{Binding}"/>
                                
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E8F4FD"/>
                                            <Setter Property="Foreground" Value="#000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E8F4FD"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,14"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                </Style>
                            </DataGrid.Resources>
                            
                            <DataGrid.Columns>
                                <!-- Name Column -->
                                <DataGridTemplateColumn Header="NAME" 
                                                        Width="180" 
                                                        MinWidth="100"
                                                        MaxWidth="400"
                                                        SortMemberPath="Name"
                                                        Visibility="{Binding Data.ShowNameColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#107C10" Width="4" Height="20" CornerRadius="2" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Table Column -->
                                <DataGridTemplateColumn Header="TABLE" 
                                                        Width="130" 
                                                        MinWidth="80"
                                                        MaxWidth="300"
                                                        SortMemberPath="Table"
                                                        Visibility="{Binding Data.ShowTableColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F0F0F0" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Table}" FontSize="12" Foreground="#666"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Expression Column -->
                                <DataGridTemplateColumn Header="EXPRESSION" 
                                                        Width="300" 
                                                        MinWidth="150"
                                                        MaxWidth="800"
                                                        SortMemberPath="Expression"
                                                        Visibility="{Binding Data.ShowExpressionColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Expression}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="12" 
                                                       Foreground="#5C2D91"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Expression}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Description Column -->
                                <DataGridTemplateColumn Header="DESCRIPTION" 
                                                        Width="180" 
                                                        MinWidth="100"
                                                        MaxWidth="500"
                                                        SortMemberPath="Description"
                                                        Visibility="{Binding Data.ShowDescriptionColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" 
                                                       FontSize="12" 
                                                       Foreground="#666"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Description}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Format Column -->
                                <DataGridTemplateColumn Header="FORMAT" 
                                                        Width="100" 
                                                        MinWidth="60"
                                                        MaxWidth="200"
                                                        SortMemberPath="FormatString"
                                                        Visibility="{Binding Data.ShowFormatStringColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FormatString}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="11" 
                                                       Foreground="#888"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Hidden Column -->
                                <DataGridTemplateColumn Header="VISIBILITY" 
                                                        Width="90"
                                                        MinWidth="70"
                                                        MaxWidth="150"
                                                        Visibility="{Binding Data.ShowIsHiddenColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Visible"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Text" Value="Hidden"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Display Folder Column -->
                                <DataGridTemplateColumn Header="FOLDER" 
                                                        Width="120" 
                                                        MinWidth="80"
                                                        MaxWidth="300"
                                                        SortMemberPath="DisplayFolder"
                                                        Visibility="{Binding Data.ShowDisplayFolderColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📁" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayFolder}" 
                                                           FontSize="12" 
                                                           Foreground="#666"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Data Type Column -->
                                <DataGridTemplateColumn Header="DATA TYPE" 
                                                        Width="90" 
                                                        MinWidth="70"
                                                        MaxWidth="200"
                                                        SortMemberPath="DataType"
                                                        Visibility="{Binding Data.ShowDataTypeColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#E3F2FD" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding DataType}" FontSize="11" Foreground="#1565C0" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Detail Rows Expression Column -->
                                <DataGridTemplateColumn Header="DETAIL ROWS" 
                                                        Width="200" 
                                                        MinWidth="100"
                                                        MaxWidth="500"
                                                        SortMemberPath="DetailRowsExpression"
                                                        Visibility="{Binding Data.ShowDetailRowsExpressionColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DetailRowsExpression}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="11" 
                                                       Foreground="#666"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding DetailRowsExpression}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- KPI Column -->
                                <DataGridTemplateColumn Header="KPI" 
                                                        Width="100" 
                                                        MinWidth="70"
                                                        MaxWidth="250"
                                                        SortMemberPath="KPI"
                                                        Visibility="{Binding Data.ShowKPIColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#FCE4EC" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left"
                                                    Visibility="{Binding KPI, Converter={StaticResource StringToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📊" FontSize="10" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding KPI}" FontSize="11" Foreground="#C2185B"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- State Column -->
                                <DataGridTemplateColumn Header="STATE" 
                                                        Width="100" 
                                                        MinWidth="70"
                                                        MaxWidth="200"
                                                        SortMemberPath="State"
                                                        Visibility="{Binding Data.ShowStateColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="NoData">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding State}"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="SemanticError">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="NoData">
                                                                    <Setter Property="Foreground" Value="#EF6C00"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Error Message Column -->
                                <DataGridTemplateColumn Header="ERROR" 
                                                        Width="200" 
                                                        MinWidth="100"
                                                        MaxWidth="500"
                                                        SortMemberPath="ErrorMessage"
                                                        Visibility="{Binding Data.ShowErrorMessageColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ErrorMessage}" 
                                                       FontSize="11" 
                                                       Foreground="#C62828"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ErrorMessage}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Lineage Tag Column -->
                                <DataGridTemplateColumn Header="LINEAGE TAG" 
                                                        Width="150" 
                                                        MinWidth="80"
                                                        MaxWidth="400"
                                                        SortMemberPath="LineageTag"
                                                        Visibility="{Binding Data.ShowLineageTagColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LineageTag}" 
                                                       FontFamily="Consolas" 
                                                       FontSize="10" 
                                                       Foreground="#888"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding LineageTag}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Modified Time Column -->
                                <DataGridTemplateColumn Header="MODIFIED" 
                                                        Width="140" 
                                                        MinWidth="100"
                                                        MaxWidth="250"
                                                        SortMemberPath="ModifiedTime"
                                                        Visibility="{Binding Data.ShowModifiedTimeColumn, Source={StaticResource Proxy}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🕐" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModifiedTime, StringFormat='{}{0:g}'}" 
                                                           FontSize="11" 
                                                           Foreground="#666"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Columns Tab -->
            <TabItem Header="📋 Columns">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Columns" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Columns}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Table" Binding="{Binding Table}" Width="120"/>
                            <DataGridTextColumn Header="Data Type" Binding="{Binding DataType}" Width="100"/>
                            <DataGridCheckBoxColumn Header="Calculated" Binding="{Binding IsCalculated}" Width="80"/>
                            <DataGridTextColumn Header="Expression" Binding="{Binding Expression}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Hidden" Binding="{Binding IsHidden}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Relationships Tab -->
            <TabItem Header="🔗 Relationships">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Relationships" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Relationships}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="From Table" Binding="{Binding FromTable}" Width="120"/>
                            <DataGridTextColumn Header="From Column" Binding="{Binding FromColumn}" Width="120"/>
                            <DataGridTextColumn Header="To Table" Binding="{Binding ToTable}" Width="120"/>
                            <DataGridTextColumn Header="To Column" Binding="{Binding ToColumn}" Width="120"/>
                            <DataGridTextColumn Header="Cardinality" Binding="{Binding Cardinality}" Width="120"/>
                            <DataGridTextColumn Header="Cross Filter" Binding="{Binding CrossFilterDirection}" Width="100"/>
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Dependencies Tab -->
            <TabItem Header="🔄 Dependencies">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Dependencies" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Dependencies}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Object Name" Binding="{Binding ObjectName}" Width="150"/>
                            <DataGridTextColumn Header="Object Type" Binding="{Binding ObjectType}" Width="120"/>
                            <DataGridTextColumn Header="Depends On" Binding="{Binding DependsOn}" Width="*"/>
                            <DataGridTextColumn Header="Dependency Type" Binding="{Binding DependencyType}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Unused Objects Tab -->
            <TabItem Header="⚠️ Unused Objects">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Unused Objects" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Objects that may be candidates for removal to optimize your model" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding UnusedObjects}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#FFF8E7"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding ObjectType}" Width="120"/>
                            <DataGridTextColumn Header="Table" Binding="{Binding Table}" Width="120"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Impact Analysis Tab -->
            <TabItem Header="💥 Impact Analysis">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Impact Analysis" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Understand the downstream impact of changes to your model objects" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ImpactAnalysis}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F8F8F8"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Object Name" Binding="{Binding ObjectName}" Width="150"/>
                            <DataGridTextColumn Header="Object Type" Binding="{Binding ObjectType}" Width="100"/>
                            <DataGridTextColumn Header="Impacted Object" Binding="{Binding ImpactedObject}" Width="150"/>
                            <DataGridTextColumn Header="Impact Type" Binding="{Binding ImpactType}" Width="150"/>
                            <DataGridTemplateColumn Header="Severity" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="5,2" CornerRadius="3" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                            <Setter Property="Background" Value="#FFE0E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="High">
                                                            <Setter Property="Background" Value="#FFE8CC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                            <Setter Property="Background" Value="#FFF8CC"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Low">
                                                            <Setter Property="Background" Value="#E0FFE0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Severity}" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Welcome Message when not connected -->
        <Border Grid.Row="2" 
                Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                Background="#F5F5F5"
                CornerRadius="8"
                Padding="40">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔌" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Welcome to PowerInsighter" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Connect to a Power BI Desktop instance to analyze your data model" 
                           FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <TextBlock Text="Features:" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="📊 Model Overview - Get a quick summary of your model" Margin="0,5"/>
                    <TextBlock Text="📐 Measures - View all measures and their expressions" Margin="0,5"/>
                    <TextBlock Text="📋 Columns - Explore columns and calculated columns" Margin="0,5"/>
                    <TextBlock Text="🔗 Relationships - Analyze table relationships" Margin="0,5"/>
                    <TextBlock Text="🔄 Dependencies - Understand object dependencies" Margin="0,5"/>
                    <TextBlock Text="⚠️ Unused Objects - Find optimization opportunities" Margin="0,5"/>
                    <TextBlock Text="💥 Impact Analysis - Assess change impacts" Margin="0,5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
